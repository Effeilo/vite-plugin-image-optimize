{
  "name": "vite-plugin-image-optimize",
  "version": "2.0.0",
  "description": "Vite plugin that generates AVIF and WebP images and optimizes all image assets during the build process for better performance.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "image",
    "image-optimize",
    "image-compression",
    "webp",
    "avif",
    "sharp",
    "vite-plugin-webp",
    "vite-plugin-avif",
    "vite-plugin-image-optimize"
  ],
  "author": "Effeilo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.9",
    "typescript": "^5.8.3",
    "vite": "^7.0.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "globby": "^13.2.2",
    "sharp": "^0.34.5",
    "svgo": "^3.3.2"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Effeilo/vite-plugin-image-optimize"
  },
  "bugs": {
    "url": "https://github.com/Effeilo/vite-plugin-image-optimize/issues"
  },
  "homepage": "https://github.com/Effeilo/vite-plugin-image-optimize"
}
